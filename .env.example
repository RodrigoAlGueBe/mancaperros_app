# =============================================================================
# MANCAPERROS APP - Environment Configuration Template
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in all required values (marked with REQUIRED)
# 3. NEVER commit .env to version control!
#
# =============================================================================

# ======================== APPLICATION SETTINGS ================================

# Application name (optional, defaults to "Mancaperros App")
APP_NAME=Mancaperros App

# Application version
VERSION=1.0.0

# Environment: development, staging, or production
# - development: Enables debug mode, uses relaxed security
# - staging: Similar to production but for testing
# - production: Strict security, requires all credentials
ENVIRONMENT=development

# Debug mode (true/false)
# Set to false in production!
DEBUG=true

# ======================== SECURITY SETTINGS ===================================
#
# WARNING: The credentials below were previously exposed in the codebase.
# You MUST rotate these credentials immediately:
# 1. Generate a new SECRET_KEY
# 2. Change database password in Railway/your provider
# 3. Update this .env file with new values
#
# =============================================================================

# REQUIRED: Secret key for JWT token signing
# Generate a secure key with: openssl rand -hex 32
# Or in Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# JWT algorithm (HS256 is recommended)
ALGORITHM=HS256

# Access token expiration in minutes (default: 180 = 3 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=180

# ======================== DATABASE SETTINGS ===================================
#
# For MySQL/MariaDB (production):
#   Set USE_SQLITE=false and configure DB_* variables
#
# For SQLite (local development only):
#   Set USE_SQLITE=true
#
# =============================================================================

# Use SQLite for local development (true/false)
# Set to false for production!
USE_SQLITE=false

# REQUIRED: Database username
DB_USER=root

# REQUIRED: Database password
# Never use the default password! Change this immediately.
DB_PASSWORD=your_secure_password_here

# Database host
# Examples:
#   - localhost (local development)
#   - yamanote.proxy.rlwy.net (Railway)
#   - your-db.mysql.database.azure.com (Azure)
DB_HOST=localhost

# Database port (MySQL default: 3306)
DB_PORT=3306

# Database name
DB_NAME=mancaperros

# SQLite URL (only used if USE_SQLITE=true)
SQLITE_URL=sqlite:///./mancaperros_app.db

# ======================== CORS SETTINGS =======================================
#
# Configure allowed origins for Cross-Origin Resource Sharing
#
# Formats supported:
#   - Comma-separated: http://localhost:3000,http://localhost:5173
#   - JSON array: ["http://localhost:3000", "http://localhost:5173"]
#
# =============================================================================

# Allowed CORS origins (comma-separated or JSON array)
CORS_ORIGINS=http://localhost,http://localhost:8080,http://localhost:3100,http://localhost:5173

# For production, add your frontend domain:
# CORS_ORIGINS=https://your-frontend-domain.com,https://blue-water-043a88803.6.azurestaticapps.net

# Allow credentials in CORS requests (true/false)
CORS_ALLOW_CREDENTIALS=true

# ======================== APPLICATION DEFAULTS ================================

# Default order of routine muscle groups (JSON array)
ROUTINE_GROUP_ORDER_DEFAULT=["chest", "back", "shoulders", "legs"]

# =============================================================================
# SECURITY CHECKLIST FOR PRODUCTION
# =============================================================================
#
# Before deploying to production, verify:
#
# [ ] SECRET_KEY is a unique, randomly generated 64-character hex string
# [ ] DB_PASSWORD has been changed from any previously exposed value
# [ ] DEBUG=false
# [ ] ENVIRONMENT=production
# [ ] USE_SQLITE=false
# [ ] CORS_ORIGINS only contains trusted domains
# [ ] .env file is NOT committed to git (check .gitignore)
# [ ] All database credentials have been rotated after exposure
#
# =============================================================================
